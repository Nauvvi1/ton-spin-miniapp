{
  "name": "ton-spin-miniapp-ts",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot + TON spin mini app on TypeScript",
  "scripts": {
    "dev": "concurrently -n server,bot,miniapp -c cyan,magenta,yellow \"npm:dev:server\" \"npm:dev:bot\" \"npm:dev:miniapp\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:bot": "tsx watch apps/bot/src/index.ts",
    "dev:miniapp": "vite --config vite.config.ts",
    "build": "npm run build:miniapp && npm run build:server && npm run build:bot",
    "build:server": "tsc -p apps/server/tsconfig.json",
    "build:bot": "tsc -p apps/bot/tsconfig.json",
    "build:miniapp": "vite build --config vite.config.ts",
    "start:server": "node dist/server/apps/server/src/index.js",
    "start:bot": "node dist/bot/apps/bot/src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "grammy": "^1.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
